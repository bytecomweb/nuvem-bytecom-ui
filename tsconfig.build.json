{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "outDir": "dist",
    "noEmit": false
  },
  "include": [
    "src/index.ts",
    "src/**/*.ts",
    "src/**/*.vue",
    "src/env.d.ts"
  ],
  "exclude": [
    "src/playground/**"
  ]
}